{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      { "source": "http://ayah-daily.web.app/**", "destination": "https://ayah-daily.web.app/:splat", "type": 301 },
      { "source": "/", "destination": "/en", "type": 301 },
      { "source": "/about", "destination": "/en/about", "type": 301 },
      { "source": "/about/", "destination": "/en/about", "type": 301 },
      { "source": "/faq", "destination": "/en/faq", "type": 301 },
      { "source": "/faq/", "destination": "/en/faq", "type": 301 },
      { "source": "/how-it-works", "destination": "/en/how-it-works", "type": 301 },
      { "source": "/how-it-works/", "destination": "/en/how-it-works", "type": 301 }
    ],
    "headers": [
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "**/*.@(js|css|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=60" }
        ]
      }
    ],
    "rewrites": [
      { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
      { "source": "/robots.txt", "destination": "/robots.txt" }
    ]
  }
}
